# .env for Email Parser Service

# Gmail Account Credentials
# This is the email address of the dedicated Gmail account (e.g., job.michael.naatjes@gmail.com)
GMAIL_USER="your.gmail.address@gmail.com"

# The 16-digit App Password generated from your Google Account security settings.
# IMPORTANT: DO NOT use your regular Gmail password here.
GMAIL_APP_PASSWORD="obofgjwymyumfdnw"

# n8n Webhook URL
# This is the URL provided by your n8n workflow's Webhook node.
N8N_WEBHOOK_URL=""

# Gmail Label for Job Alerts
# This is the name of the Gmail label/folder where job alert emails are moved to.
GMAIL_JOB_ALERTS_LABEL="job-alerts"
